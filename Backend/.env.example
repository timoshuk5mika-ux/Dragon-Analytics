APP_NAME=Dragon Analytics API
DEBUG=True
API_V1_PREFIX=/api/v1

POSTGRES_DB=dragon_analytics
POSTGRES_USER=dragon_user
POSTGRES_PASSWORD=dragon_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://dragon_user:dragon_password@localhost:5432/dragon_analytics

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
